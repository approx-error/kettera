}

determine_input_parameters() {
    local input="$1" # The input file to check

    local SUCCESS=0
    local FMT_ERR_1=1
    local FMT_ERR_2=2
    local FMT_ERR_3=3
    local FMT_ERR_4=4
    local FMT_ERR_5=5

    local integer_re="^[0-9]+$"
    local float_re="^[0-9]+\.[0-9]+$"

    local point_line xmax_line
    local awk_pointcount awk_xmax
    local pointcount xmax

    # Find the line number in the input file where the point count and x max are
    point_line="$(grep -n "PointCount" "$input" | awk -F":" '{print $1}')"
    xmax_line="$(grep -n "XMax" "$input" | awk -F":" '{print $1}')"

    if [[ "$point_line" -ne "$xmax_line" ]]; then
        return "$FMT_ERR_1"
    fi
    if [[ -z "$point_line" ]]; then 
        return "$FMT_ERR_2"
    fi
    if [[ "${#point_line}" -gt 2 ]]; then
        return "$FMT_ERR_3"
    fi

    awk_pointcount="FNR==$point_line{print\$6}"
    awk_xmax="FNR==$xmax_line{print\$8}"
    pointcount="$(awk -F'[=;]' "$awk_pointcount" "$input")" 
    xmax="$(awk -F'[=;]' "$awk_xmax" "$input")"

    if [[ ! "$pointcount" =~ $integer_re ]]; then
        return "$FMT_ERR_4"
    fi
    if [[ ! "$xmax" =~ $float_re ]]; then
        return "$FMT_ERR_5"
    fi

    echo "$pointcount $xmax"
    return "$SUCCESS"
}

extract_frame () {
    local index="$1" # Tells how many frames have already been extracted
    local expected_point_count="$2" # This value is used to make sure the input
        # file has the correct value for the PointCount parameter
    local expected_x_max="$3" # This value is used to make sure the input file
        # has the correct value for the XMax parameter
    local input="$4" # The input file to extract from
    local frame="$5" # The frame to extract from the input file
    local output="$6" # The output file to extract to

    local SUCCESS=0
    local OPT_ERROR=1
    local VAL_ERROR=2
    local FILE_ERROR=3
    local FMT_ERROR=4
    local RANGE_ERROR=5
    local PARAM_ERROR=6

    local integer_re="^[0-9]+$"
    local float_re="^[0-9]+\.[0-9]+$"

    local frame_line point_line xmax_line
    local awk_framecount awk_pointcount awk_xmax
    local framecount pointcount xmax
    local max_frame
    local grep_frame sed_frame
    local frame_lower frame_upper frame_last

    # Find the line number in the input file where the frame count, point count and x max are
    frame_line="$(grep -n "FrameCount" "$input" | awk -F":" '{print $1}')"
    point_line="$(grep -n "PointCount" "$input" | awk -F":" '{print $1}')"
    xmax_line="$(grep -n "XMax" "$input" | awk -F":" '{print $1}')"

    if [[ "$frame_line" -ne "$point_line" ]] || [[ "$frame_line" -ne "$xmax_line" ]]; then
        echo "ketract: FORMAT ERROR: FrameCount, PointCount and XMax are not on same line in '$input'"
        return "$FMT_ERROR"
    fi
    if [[ -z "$frame_line" ]]; then 
        echo "ketract: FORMAT ERROR: Line containing FrameCount, PointCount and XMax not found in '$input'" 
        return "$FMT_ERROR";
    fi
    if [[ "${#frame_line}" -gt 2 ]]; then
        echo "ketract: FORMAT ERROR: Multiple instances of FrameCount, PointCount and XMax"
        echo "or not found in the first 99 lines of '$input'"
        return "$FMT_ERROR"
    fi

    awk_framecount="FNR==$frame_line{print\$2}"
    awk_pointcount="FNR==$point_line{print\$6}"
    awk_xmax="FNR==$xmax_line{print\$8}"
    framecount="$(awk -F'[=;]' "$awk_framecount" "$input")" 
    pointcount="$(awk -F'[=;]' "$awk_pointcount" "$input")" 
    xmax="$(awk -F'[=;]' "$awk_xmax" "$input")"

    if [[ ! "$framecount" =~ $integer_re ]]; then
        echo "ketract: FORMAT ERROR: Value of FrameCount on line $frame_line in '$input'"
        echo "is in wrong place or not a positive integer"
        return "$FMT_ERROR"
    fi
    if [[ ! "$pointcount" =~ $integer_re ]]; then
        echo "ketract: FORMAT ERROR: Value of PointCount on line $point_line in '$input'"
        echo "is in wrong place or not a positive integer"
        return "$FMT_ERROR"
    fi
    if [[ ! "$xmax" =~ $float_re ]]; then
        echo "ketract: FORMAT ERROR: Value of XMax on line $xmax_line in '$input'"
        echo "is in wrong place or not a positive floating point number"
        return "$FMT_ERROR"
    fi

    if [[ "$pointcount" != "$expected_point_count" ]]; then
        echo "ketract: PARAMETER ERROR: Value '$pointcount' for PointCount in file '$input'"
        echo "does not match the expected PointCount value '$expected_point_count'!"
        return "$PARAM_ERROR"
    fi

    if [[ "$xmax" != "$expected_x_max" ]]; then
        echo "ketract: PARAMETER ERROR: Value '$xmax' for XMax in file '$input'"
        echo "does not match the expected XMax value '$expected_x_max'!"
        return "$PARAM_ERROR"
    fi

    max_frame=$(("$framecount" - 1))

    if [[ "$frame" -gt "$max_frame" ]]; then
        echo "ketract: RANGE ERROR: Chosen frame '$frame' is outside the range of frames in '$input'"
        return "$RANGE_ERROR"
    fi

    if [[ "$frame" -eq -1 ]]; then
        frame="$max_frame"
    fi

    grep_frame="^Frame=$frame$" # The ^ and $ are there to for example stop Frame=10 from matching Frame=1

    frame_line="$(grep -n "$grep_frame" "$input" | awk -F":" '{print$1}')"

    if [[ -z "$frame_line" ]]; then 
        echo "ketract: FORMAT ERROR: Could not find frame '$frame' in '$input'" 
        return "$FMT_ERROR";
    fi

    frame_lower=$(("$frame_line" + 1))
    frame_upper=$(("$frame_line" + "$pointcount"))
    frame_last=$(("$frame_upper" + 1))

    sed_frame="${frame_lower},${frame_upper}p;${frame_last}q"


    echo "Wave=$index" >> "$output"
    echo "$(sed -n "$sed_frame" "$input" | cut -d';' -f2,3)" >> "$output"

    return "$SUCCESS"
}

main() {
    
    local SUCCESS=0
    local OPT_ERROR=1
    local VAL_ERROR=2
    local FILE_ERROR=3
    local FMT_ERROR=4
    local RANGE_ERROR=5
    local PARAM_ERROR=6

    local frame_re="^[-]?[0-9]+$"

    local current
    local frames=()
    local default_frame=-1
    local frame_count=0
    local input_files=()
    local input_count=0
    local output

    if [[ "$#" -eq 0 ]]; then
        show_usage
        exit "$SUCCESS";
    fi

    while [[ "$#" -gt 0 ]]; do
        current="$1"
        case $current in
            "--help")
                show_help 
                exit "$SUCCESS";
                ;;
            "--version")
                show_version
                exit "$SUCCESS";
                ;;
            "-i"|"--input")
                shift
                if [[ "$#" -eq 0 ]]; then
                    echo "ketract: OPTION ERROR: No input file(s) provided for flag -i!"
                    exit "$OPT_ERROR";
                fi
                echo "$1"

                for i in ${1//,/ }; do # Iterating through each comma separated string in the current $1
                    echo "$i"

                    if [[ ! -f "$i" ]]; then
                        echo "ketract: FILE ERROR: File '$i' does not exist!"
                        exit "$FILE_ERROR";
                    fi

                    input_files+=("$i")
                done
                ;;
            "-o"|"--output")
                shift
                if [[ "$#" -eq 0 ]]; then
                    echo "ketract: OPTION ERROR: No output file provided for flag -o!"
                    exit "$OPT_ERROR";
                fi
                output="$1"
                ;;
            "-f"|"--frame")
                shift
                if [[ "$#" -eq 0 ]]; then
                    echo "ketract: OPTION ERROR: No frame number(s) provided for flag -f!"
                    exit "$OPT_ERROR";
                fi
                
                for i in ${1//,/ }; do # Iterating through each comma separated string in the current $1
                    echo "$i"
                    if [[ ! "$i" =~ $frame_re ]]; then
                        echo "ketract: VALUE ERROR: '$i' is not an integer and cannot be used as a frame!"
                        exit "$VAL_ERROR";
                    fi

                    if [[ "$i" -lt -1 ]]; then
                        echo "ketract: VALUE ERROR: Frame number must be >= -1 and '$i' is too small!"
                        exit "$VAL_ERROR";
                    fi

                    frames+=("$i")
                done 
                ;;
            *)
                echo "ketract: OPTION ERROR: Option '$1' is not recognized!"
                echo "Run 'ketract --help' for more information"
                exit "$OPT_ERROR"
                ;;
        esac
        shift
    done

    if [[ -z "$output" ]]; then
        echo "ketract: OPTION ERROR: No output file provided!"
        exit "$OPT_ERROR"
    fi

    echo "DEBUG: input_file(s): ${input_files[*]}"
    echo "DEBUG: amount of input files: ${#input_files[@]}"
    echo "DEBUG: frame(s): ${frames[*]}"
    echo "DEBUG: amount of frames: ${#frames[@]}"

    input_count="${#input_files[@]}"
    frame_count="${#frames[@]}"

    if (( "$input_count" == 0 )); then
        echo "ketract: OPTION ERROR: No input files provided!"
        exit "$OPT_ERROR";
    fi
    
    if (( "$frame_count" == 0 )); then
        for (( i = 0 ; i <= $(("$input_count" - 1)) ; i++ )); do
            frames["$i"]=-1
        done
    elif (( "$frame_count" != "$input_count" )); then
        echo "ketract: VALUE ERROR: Number of frames provided does not match number of input files provided!"
        exit "$VAL_ERROR";
    fi

    echo "DEBUG: frame(s) after: ${frames[*]}"
    echo "DEBUG: amount of frames after: ${#frames[@]}"

    local first_input=${input_files[0]}
    local stat expected_point_count expected_x_max
    read -r expected_point_count expected_x_max < <(determine_input_parameters "$first_input")
    stat="$?"

    case $stat in
        0)
            echo "status 0"
            ;;
        1)
            echo "ketract: FORMAT ERROR: FrameCount, PointCount and XMax are not on same line in '$first_input'"
            exit "$FMT_ERROR"
            ;;
        2)
            echo "ketract: FORMAT ERROR: Line containing PointCount and XMax not found in '$first_input'" 
            exit "$FMT_ERROR"
            ;;
        3)
            echo "ketract: FORMAT ERROR: Multiple instances of PointCount and XMax"
            echo "or not found in the first 99 lines of '$input'"
            exit "$FMT_ERROR"
            ;;
        4)
            echo "ketract: FORMAT ERROR: Value of PointCount on line $point_line in '$input'"
            echo "is in wrong place or not a positive integer"
            exit "$FMT_ERROR"
            ;;
        5)
            echo "ketract: FORMAT ERROR: Value of XMax on line $xmax_line in '$input'"
            echo "is in wrong place or not a positive floating point number"
            exit "$FMR_ERROR"
            ;;
        *)
            echo "ketract: determine_input_parameters status not 0-5"
            ;;
    esac

    echo "# This file was generated by ketract and contains a wavefunction / wavefunctions" > "$output"
    echo "# that can be used as an initial condition / initial conditions for simulations in kettera" >> "$output"
    echo "WaveCount=$input_count;PointCount=$expected_point_count;XMax=$expected_x_max" >> "$output"
    echo "Real;Imag" >> "$output"

    for (( i = 0 ; i <= $(("$input_count" - 1)) ; i++ )); do
        extract_frame "$i" "$expected_point_count" "$expected_x_max" "${input_files[$i]}" "${frames[$i]}" "$output"
        stat="$?"
        if (( "$stat" != "$SUCCESS" )); then
            rm -f "$output"
            exit "$stat"
        fi
    done

    exit "$SUCCESS";
}

main "$@"

