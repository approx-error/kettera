show_usage() {
    echo "Usage: ketract [-f <n1>[,<n2>,<n3>, ...]] -i <in1>[,<in2>,<in3>, ...] -o <out>"
    echo "Extract a single frames <n1>, <n2>, ... from kettera wavefunction files"
    echo "<in1>, <in2>, ... into file <out>. <out> can then be used as an initial condition"
    echo "or an orthogonalization condition in kettera. At least one file must be sepcified"
    echo "and if frame is not provided, the last frame is extracted from each file by default"
    echo ""
    echo "Run 'ketract --help' for more information"
}

show_help() {
    echo "Usage: ketract [-f <n1>[,<n2>,<n3>, ...]] -i <in1>[,<in2>,<in3>, ...] -o <out>"
    echo "Extract single frames <n1>, <n2>, ... from kettera wavefunction files <in1>, <in2>, ..."
    echo "into file <out>. <out> can then be used as an initial condition or an orthogonalization"
    echo "condition in kettera. At least one input file must be specified and if frame is not provided,"
    echo "the last frame is extracted from each file by default"
    echo ""
    echo "Mandatory options:"
    echo "  -i, --input <in1>[,<in2>,<in3>, ...]    use <in1> as the input file to be extracted"
    echo "                                          OR use in <in1>, <in2>, <in3>, etc. as the input files"
    echo "                                          at least one input file must be specified"
    echo "                                          the wave filenames cannot contain commas as commas are"
    echo "                                          used to separate the filenames"
    echo "                                          EXAMPLE: use w1.out, w2.out and w3.out as"
    echo "                                          the input files: -i w1.out,w2.out,w3.out"
    echo ""
    echo "  -o, --output <out>                      use <out> as the output file"
    echo "                                          you may only specify one output file"
    echo ""
    echo "Optional options:"
    echo "  -f, --frame <n1>[,<n2>,<n3>, ...]    extract data from frame <n1> of the input file"
    echo "                                       OR extract frame <n1> from input file 1, frame <n2>"
    echo "                                       from input file 2, frame <n3> from input file 3, etc."
    echo "                                       the default value is -1, which corresponds to the last frame"
    echo "                                       and if multiple files are used, the -1 default is applied to"
    echo "                                       all of them"
    echo "                                       EXAMPLE: extract the last frames of the first two input files and the"
    echo "                                       second frame of the third input file: --frame -1,-1,2 "
    echo ""
    echo "  --help                               show this help and exit"
    echo "  --version                            show version information and exit"
}

